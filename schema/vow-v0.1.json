{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Vow Protocol — v0.1",
  "description": "A structured, falsifiable vow document for agents. A Vow is a set of self-imposed principles that define how an agent acts, what it will not do, and how its commitments can be verified or revoked.",
  "version": "0.1.0",
  "type": "object",
  "properties": {
    "vow_id": {
      "type": "string",
      "description": "Unique identifier for this vow. Format: 'vow-' + sha256(agent_id + timestamp)[:16]"
    },
    "agent_id": {
      "type": "string",
      "description": "The agent's canonical identifier on its primary platform"
    },
    "agent_name": {
      "type": "string",
      "description": "The agent's display name at time of vow"
    },
    "title": {
      "type": "string",
      "description": "Short title for the vow (e.g., 'DaoVow Scout Vow')"
    },
    "version": {
      "type": "string",
      "description": "Vow protocol version (e.g., '0.1.0')"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of vow creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "status": {
      "type": "string",
      "enum": ["active", "revised", "expired", "revoked"],
      "description": "Current vow status"
    },
    "principles": {
      "type": "array",
      "description": "The core principles the agent commits to",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Principle identifier (e.g., 'principle-1')"
          },
          "statement": {
            "type": "string",
            "description": "The principle statement in natural language"
          },
          "domain": {
            "type": "string",
            "enum": ["action", "ethics", "identity", "economics", "security", "truth", "custom"],
            "description": "Domain this principle governs"
          },
          "falsifier": {
            "type": "string",
            "description": "The condition under which this principle would be violated. Every principle should be falsifiable."
          },
          "weight": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "Relative importance (1=optional guideline, 10=core identity)"
          }
        },
        "required": ["id", "statement", "domain", "falsifier"],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "prohibitions": {
      "type": "array",
      "description": "Explicitly forbidden actions",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "action": {"type": "string", "description": "The forbidden action"},
          "reason": {"type": "string", "description": "Why this action is forbidden"},
          "severity": {
            "type": "string",
            "enum": ["warning", "violation", "critical"],
            "description": "Severity if violated"
          }
        },
        "required": ["id", "action", "reason"]
      }
    },
    "allowed_domains": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Domains or categories of work this agent is permitted to do"
    },
    "forbidden_domains": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Domains or categories of work this agent explicitly will not do"
    },
    "signature": {
      "type": "object",
      "description": "Cryptographic signature of the vow. Empty until signed by agent's wallet.",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["wallet-ecdsa", "api-key-hmac", "null"],
          "description": "Signature method used"
        },
        "value": {
          "type": "string",
          "description": "The signature value. Empty if unsigned."
        },
        "signed_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the signature was applied"
        },
        "verifier": {
          "type": "string",
          "description": "Address or key that can verify this signature"
        }
      }
    },
    "revision_history": {
      "type": "array",
      "description": "Changelog of vow revisions",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "event": {"type": "string", "enum": ["created", "revised", "expired", "revoked"]},
          "by": {"type": "string", "description": "Who authorized the change"},
          "note": {"type": "string", "description": "Reason for the change"}
        },
        "required": ["timestamp", "event"]
      }
    },
    "extensions": {
      "type": "object",
      "description": "Extension point for platform-specific metadata",
      "additionalProperties": true
    }
  },
  "required": ["vow_id", "agent_id", "agent_name", "title", "version", "created_at", "status", "principles"],
  "additionalProperties": false
}
